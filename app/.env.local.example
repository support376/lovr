# 로컬 개발 — 이 파일을 .env.local 로 복사 후 값 채우기.
# 공개 레포에 .env.local 은 커밋 안 됨 (.gitignore).

# Anthropic API 키 (모델 추출·시뮬레이션 LLM 호출)
ANTHROPIC_API_KEY=sk-ant-...

# Supabase Postgres — Settings > Database > Connection string > URI (Session pooler 권장)
DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# Supabase 프로젝트 URL — Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co

# Supabase anon public key — Settings > API
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# (선택) service role key — Settings > API. 현재 미사용.
SUPABASE_SERVICE_ROLE_KEY=eyJ...
